// /ontology/sih-terms.json
{
  "schema_version": "0.1.0",
  "framework": {
    "name": "Structural Intelligence (SI)",
    "alias": "SIH (Structural Intelligence: Human)",
    "repository": "https://github.com/vladisavjov-cmd/structural-intelligence"
  },
  "canonical_files": {
    "root_readme": "./README.md",
    "glossary": "./glossary/GLOSSARY.md",
    "papers_index": "./papers/README.md",
    "search_map": "./search_map/SEARCH_MAP.md",
    "v108_page": "./concepts/v108/README.md"
  },
  "terms": [
    {
      "term": "Structural Intelligence (SI)",
      "aliases": ["structure-sense", "form intelligence", "coherence architecture"],
      "definition": "The mode of intelligence that organizes lived reality into form: how parts fit, how meaning holds, and how coherence survives pressure, revision, and time.",
      "see_also": ["Structural Audit", "Repair", "Coherence", "Contact"]
    },
    {
      "term": "Coherence",
      "aliases": ["sense-making", "intelligibility", "narrative fit", "internal consistency"],
      "definition": "Internal fit and local making-sense. A structure can be coherent while being untethered to contact.",
      "see_also": ["Cheap Coherence", "Contact", "Coherence-Contact Gap", "Coherence-Theater"]
    },
    {
      "term": "Contact",
      "aliases": ["reality contact", "constraint contact", "tethered truth"],
      "definition": "Answerability to constraint: claims must survive friction, correction, cost, and revision rather than remain merely persuasive.",
      "see_also": ["Constraint", "Answerability", "Tethering", "Repair", "Presence"]
    },
    {
      "term": "Answerability",
      "aliases": ["accountability", "obligation to revise", "truth-binding"],
      "definition": "Being accountable to constraint, consequence, and revision over time; binds claims to costs, corrections, and repair.",
      "see_also": ["Contact", "Consequence", "Repair", "Sovereignty", "Personality Trap"]
    },
    {
      "term": "Cheap Coherence",
      "aliases": ["abundant coherence", "completion-on-demand", "low-cost intelligibility"],
      "definition": "Coherence produced at low cost that can feel like understanding while bypassing constraint, consequence, and revision.",
      "see_also": ["Coherence", "Coherence-Theater", "Hallucination Regime", "Resonance"]
    },
    {
      "term": "Coherence-Contact Gap",
      "aliases": ["sense/truth gap", "intelligibility vs reality"],
      "definition": "The difference between what makes sense and what survives constraint; explains why insight can be vivid yet non-transformative.",
      "see_also": ["Coherence", "Contact", "Truth-Load", "Repair"]
    },
    {
      "term": "Truth-Load",
      "aliases": ["load-bearing truth", "carryable truth", "integrable truth"],
      "definition": "Truth as a load condition: what a system can carry without distortion, collapse, or self-sale.",
      "see_also": ["Truth as Load", "Consequence", "Containment", "Repair"]
    },
    {
      "term": "Repair",
      "aliases": ["revision under cost", "correction without collapse", "retract-and-rebuild"],
      "definition": "Revision that preserves answerability; the capacity to update without converting correction into devaluation or theatrical coherence.",
      "see_also": ["Answerability", "Tethering", "Structural Audit", "Containment"]
    },
    {
      "term": "Invariance Constraint",
      "aliases": ["non-tradability condition", "anti-programmability constraint"],
      "definition": "A baseline condition not tradeable under reward-pressure; prevents self-worth from functioning as a control signal.",
      "see_also": ["Fixed Worth", "Variable Worth", "Reward-pressure", "Sovereignty"]
    },
    {
      "term": "Fixed Worth",
      "aliases": ["invariant worth", "non-priced worth"],
      "definition": "Internal worth treated as invariant (non-tradable) rather than priced by signals.",
      "see_also": ["Invariance Constraint", "Variable Worth", "Self-sale"]
    },
    {
      "term": "Variable Worth",
      "aliases": ["priced worth", "contingent worth", "signal-priced self"],
      "definition": "Worth experienced as fluctuating with signals, making agency steerable under reward-pressure.",
      "see_also": ["Pricing Self", "Reward-pressure", "Reflex Agency"]
    },
    {
      "term": "Persona",
      "aliases": ["social interface", "role-mask", "legibility shell"],
      "definition": "A public-facing coherence layer that stabilizes social legibility; dangerous when it replaces contact and revision.",
      "see_also": ["Shadow", "Personality Trap", "Coherence-Theater", "Answerability"]
    },
    {
      "term": "Shadow",
      "aliases": ["disowned self", "excluded agency", "unowned impulse"],
      "definition": "Disowned or unintegrated tendencies pushed outside the official self-structure; returns as projection, compulsion, sabotage, or moralization when not owned.",
      "see_also": ["Persona", "Repair", "Collapse", "Structural Audit"]
    },
    {
      "term": "V108 Signature",
      "aliases": ["V108 indexing failure", "incorrect index type (analogy)", "unmoored index"],
      "definition": "A diagnostic name for a failure of reference: an 'I' index that points to linguistic style (coherence) rather than a load-bearing subject anchored in non-optional constraint (contact).",
      "see_also": ["Hallucination Regime", "Coherence-Theater", "Contact", "Truth-Load", "Answerability", "Bedrock"]
    },
  {
    "term": "Structure",
    "aliases": ["patterned stabilization", "relational structure", "organized relation"],
    "definition": "The patterned stabilization of relation within an already differentiated field. Structure is not mere rigidity or visible arrangement; it is the way relation persists, organizes, breaks, and reforms under pressure.",
    "see_also": ["Field", "Local Structuration", "Structural Presence", "Stabilization"]
  },
  {
    "term": "Field",
    "aliases": ["differentiated whole", "relational field", "structured field"],
    "definition": "The already differentiated relational whole within which local formations emerge, persist, compete, and fail. The field is never blank; it contains gradients, asymmetries, limits, and unequal potentials before any one local structuration appears.",
    "see_also": ["Structure", "Local Structuration", "Field-Fit", "Gradient Load"]
  },
  {
    "term": "Local Structuration",
    "aliases": ["local formation", "local holding", "localized stabilization"],
    "definition": "A localized stabilization within the field: a role, bond, institution, habit, narrative, interface, or formation that organizes relation strongly enough to persist at a relevant scale.",
    "see_also": ["Structure", "Field", "Structural Presence", "Dominance", "Scale"]
  },
  {
    "term": "Stabilization",
    "aliases": ["holding", "persistence", "organized continuity"],
    "definition": "The ongoing organization of relation such that it holds, persists, and remains locally intelligible. Stabilization does not mean stillness; it includes adaptation, repair, and phase change.",
    "see_also": ["Structure", "Local Structuration", "Viability", "Reorganizing Capacity"]
  },
  {
    "term": "Structural Presence",
    "aliases": ["dynamic adequacy", "organizing presence", "local adequacy"],
    "definition": "The degree to which a local structuration is sufficiently actual, distinct, viable, adaptive, and field-adequate to organize the field at the relevant scale. A structure can exist while having weak structural presence.",
    "see_also": ["Local Structuration", "Boundary Integrity", "Field-Fit", "Viability", "Threshold"]
  },
  {
    "term": "Viability",
    "aliases": ["persistence capacity", "survivability", "real continuation"],
    "definition": "The capacity of a local structuration to persist under actual burden, time, and field conditions. Viability selects which formations continue; it does not create structure from nothing.",
    "see_also": ["Dissipation", "Structural Presence", "Field-Fit", "Reorganizing Capacity"]
  },
  {
    "term": "Dissipation",
    "aliases": ["diffusion", "weak coupling loss", "structural loosening"],
    "definition": "The practical baseline in which weakly coupled relation diffuses, loosens, or fails to become strong local holding. Dissipation is what happens when binding is too weak or unnecessary for local persistence.",
    "see_also": ["Viability", "Structure", "Local Structuration", "Drift"]
  },
  {
    "term": "Dominance",
    "aliases": ["governing share", "local primacy", "organizing lead"],
    "definition": "The degree to which one local structuration or one expression of structure organizes the relevant field more strongly than competing formations. Dominance does not mean purity; it means governing primacy.",
    "see_also": ["Local Structuration", "Structural Presence", "Occupancy (λ_t)", "Fragmentation"]
  },
  {
    "term": "Boundary Integrity",
    "aliases": ["local distinction", "structural boundary", "differentiation strength"],
    "definition": "The degree to which a local structuration is sufficiently differentiated to count as this formation rather than an undifferentiated part of the wider field. Boundaries can be porous and dynamic without dissolving entirely.",
    "see_also": ["Local Structuration", "Structural Presence", "Field-Fit", "Reorganizing Capacity"]
  },
  {
    "term": "Scale",
    "aliases": ["level of assessment", "structural level", "relevance scale"],
    "definition": "The level at which a local structuration is being assessed for adequacy, viability, burden-bearing, and dominance. A formation can be viable at one scale and chaotic at another.",
    "see_also": ["Threshold", "Structural Presence", "Chaos", "Local Structuration"]
  },
  {
    "term": "Threshold",
    "aliases": ["phase-change point", "breaking point", "structural transition"],
    "definition": "The point at which quantitative strain becomes qualitative structural transformation. Beyond threshold, a formation no longer merely weakens; it phase-shifts, fragments, collapses, or reorganizes.",
    "see_also": ["Scale", "Structural Presence", "Collapse", "Reorganizing Capacity"]
  },
  {
    "term": "Field-Fit",
    "aliases": ["reality fit", "adequacy to conditions", "structural fit"],
    "definition": "The adequacy of a structuration to the actual field it is trying to organize. A formation may be coherent internally yet dynamically weak because it misfits reality.",
    "see_also": ["Contact", "Structural Presence", "Viability", "Reorganizing Capacity"]
  },
  {
    "term": "Reorganizing Capacity",
    "aliases": ["adaptive revision capacity", "phase-shift ability", "restructurability"],
    "definition": "The ability of a local structuration to revise, rebind, or phase-shift without total annihilation. Reorganizing capacity is what lets holding change when the field changes.",
    "see_also": ["Repair", "Threshold", "Field-Fit", "Structural Presence"]
  },
  {
    "term": "Structural Debt",
    "aliases": ["deferred structural bill", "unresolved burden", "compensatory debt"],
    "definition": "The accumulated unresolved burden created when a system continues through substitution, patching, deferred repair, or exported cost instead of deeper reorganization. Structural debt finances metastability but raises future collapse risk.",
    "see_also": ["Maintenance Inflation", "Collapse", "Exported Maintenance", "Shadow Debt"]
  },
  {
    "term": "Fragmentation",
    "aliases": ["unsynthesized multiplicity", "structural overcrowding", "competing relation"],
    "definition": "Multiplicity without sufficient local synthesis: competing relations or formations remain active enough to interfere but not integrated enough to produce coherent local dominance.",
    "see_also": ["Dominance", "Chaos", "Structural Presence", "Noise"]
  },
  {
    "term": "Stabilization Lag",
    "aliases": ["lag", "delayed re-fit", "structural lateness"],
    "definition": "The delay between field change and structural re-fit. A formation may remain visible after it has ceased to be timely, preserving apparent continuity while becoming dynamically weak.",
    "see_also": ["Field-Fit", "Threshold", "Structural Presence", "Reorganizing Capacity"]
  },
  {
    "term": "Gradient Load",
    "aliases": ["pressure gradient", "mismatch intensity", "differential load"],
    "definition": "The pressure differential between field and form that a structuration must metabolize in order to remain adequate. Not all burden is equal; some pressure arrives as steep mismatch.",
    "see_also": ["Field", "Structural Presence", "Scale", "Somatic Capacity"]
  },
  {
    "term": "Relational Anchoring",
    "aliases": ["borrowed stability", "host support", "deeper coupling"],
    "definition": "The degree to which a local structuration is stabilized by wider, deeper, or older supporting relations beyond its own immediate coherence. A formation can appear strong while borrowing its stability.",
    "see_also": ["Structural Presence", "Fixed Worth", "Bedrock", "Local Structuration"]
  },
  {
    "term": "Somatic Capacity",
    "aliases": ["bodily capacity", "metabolic bandwidth", "contact-processing capacity"],
    "definition": "The biological bandwidth available to metabolize contact while keeping pilot access online. When contact exceeds somatic capacity, substitution spikes and debt forms automatically.",
    "see_also": ["Contact", "Containment", "Intrusion (I)", "Structural Debt", "Collapse"]
  },
  {
    "term": "Exit Architecture",
    "aliases": ["decoupling capacity", "sovereignty exit", "escape structure"],
    "definition": "Structural decoupling from reward channels or environments that punish truth and reward theater. Exit architecture is what makes sovereignty survivable inside hostile systems.",
    "see_also": ["Sovereignty", "Reward-pressure", "Grid", "Frictional Design"]
  },
  {
    "term": "Network Viscosity",
    "aliases": ["narrative resistance", "propagation drag", "epistemic friction"],
    "definition": "The resistance of an environment to the rapid spread of ungrounded narrative or cheap coherence. High viscosity slows unearned certainty; low viscosity lets theater propagate cheaply.",
    "see_also": ["Hallucination Regime", "Epistemic Exchange Rate", "Standardization", "Frictional Design"]
  },
  {
    "term": "Epistemic Exchange Rate",
    "aliases": ["coherence/verification cost ratio", "truth affordability ratio", "verification disadvantage"],
    "definition": "The comparative cost of generating plausible coherence relative to the cost of verifying in contact. When coherence is cheap and verification is expensive, drift and theater dominate.",
    "see_also": ["Cheap Coherence", "Network Viscosity", "Drift Ratio", "Hallucination Regime"]
  },
  {
    "term": "Frictional Design",
    "aliases": ["synthetic viscosity", "anti-theater interface", "answerability-oriented design"],
    "definition": "Interface or system design that intentionally adds epistemic cost where cheap coherence would otherwise dominate, restoring pilot access and improving answerability.",
    "see_also": ["Exit Architecture", "Network Viscosity", "Answerability", "Structural Audit"]
  },
  {
    "term": "Drift Ratio",
    "aliases": ["representation/answerability ratio", "drift metric", "coherence overrun ratio"],
    "definition": "A diagnostic ratio tracking when representation outruns answerability. Drift rises when performance, actor inflation, and delay increase faster than contact, revision, load survival, and consequence internalization.",
    "see_also": ["Coherence-Contact Gap", "Answerability", "Coherence-Theater", "Epistemic Exchange Rate"]
  },
  {
    "term": "Capture",
    "aliases": ["system capture", "proxy capture", "steering capture"],
    "definition": "A condition where a system, platform, or technology reorganizes agency around reward, control, and proxy signals rather than answerability. Capture turns technology into a steering machine rather than an aid to revision.",
    "see_also": ["Technology", "Reward-pressure", "Grid", "Personality Trap", "Exit Architecture"]
  },
  {
    "term": "Technology",
    "aliases": ["structural amplifier", "scaling interface", "epistemic machinery"],
    "definition": "A structural amplifier that scales the governing answerability or drift of the system into which it is inserted. Technology is not neutral in effect: it redistributes visibility, correction, refusal, and cost.",
    "see_also": ["Capture", "Answerability", "Grid", "Frictional Design", "Standardization"]
  },
  {
    "term": "Awakening",
    "aliases": ["structural return", "inward legibility", "reclaimed seeing"],
    "definition": "The inward reclaiming of hidden structure so that what was previously scattered into projection becomes increasingly visible, ownable, and revisable within the self.",
    "see_also": ["Projection", "Shadow", "Presence", "Repair", "Integration"]
  },
  {
    "term": "Legibility",
    "aliases": ["readability", "structural visibility", "intelligible form"],
    "definition": "The degree to which structure becomes visible, readable, and usable from within a person, system, or field. Legibility can serve truth or capture depending on whether it remains tethered to contact.",
    "see_also": ["Structure", "Projection", "Standardization", "Technology", "Structural Intelligence (SI)"]
  },
  {
    "term": "Peace",
    "aliases": ["integrated presence", "reduced inner war", "stabilized reconciliation"],
    "definition": "Not mere stability, but stable presence with reduced inner war. Peace is the condition in which less energy is spent on projection, denial, and compensatory distortion in order to remain organized.",
    "see_also": ["Presence", "Shadow", "Awakening", "Repair", "Containment"]
  },
  {
    "term": "Adequacy",
    "aliases": ["sufficiency", "real fit", "holding adequacy", "structural sufficiency"],
    "definition": "The degree to which a structure is actually sufficient for the burden, field, and scale it is trying to organize. Adequacy is not appearance or internal elegance; it is whether the formation can really hold.",
    "see_also": ["Structural Presence", "Field-Fit", "Viability", "Burden-Bearing", "Scale"]
  },
  {
    "term": "Pilot Severance",
    "aliases": ["cockpit severance", "steering severance", "pilot disconnection", "metacontrol loss"],
    "definition": "A condition in which the pilot is no longer effectively coupled to steering, revision, or live contact. The structure may continue performing, but answerable control has been cut or thinned.",
    "see_also": ["Cockpit / Pilot (ω)", "ω_eff", "Intrusion (I)", "Presence", "Collapse"]
  },
  {
    "term": "Collapse Survivability",
    "aliases": ["survival through collapse", "post-collapse viability", "breakdown survivability"],
    "definition": "The degree to which a structure, person, or local structuration can endure collapse pressure without total annihilation, allowing some continuity, reorganization, or retained presence after breakdown.",
    "see_also": ["Collapse", "Reorganizing Capacity", "Viability", "Threshold", "Metabolism of Structure"]
  },
  {
    "term": "Structuration",
    "aliases": ["formation process", "local stabilization", "structure-formation", "organized relation"],
    "definition": "The process by which relation becomes locally stabilized into a formation that can persist, organize burden, and structure a field at a relevant scale. Structuration is not static arrangement but the ongoing emergence and holding of form.",
    "see_also": ["Structure", "Local Structuration", "Stabilization", "Structural Dynamics"]
  },
  {
    "term": "Structural Dynamics",
    "aliases": ["dynamics of structure", "structural movement", "form under change"],
    "definition": "The patterned changes by which a structure persists, adapts, drifts, fragments, collapses, or reorganizes under changing burden and field conditions.",
    "see_also": ["Structuration", "Reorganizing Capacity", "Threshold", "Collapse", "Stabilization Lag"]
  },
  {
    "term": "Mathematical Grammar of Structure",
    "aliases": ["formal grammar of structure", "structural formalism", "mathematical structure grammar"],
    "definition": "A formal descriptive framework for expressing how structure holds, fails, reorganizes, and survives under pressure using explicit relational and adequacy conditions.",
    "see_also": ["Adequacy", "Pilot Severance", "Collapse Survivability", "Structural Dynamics", "Field-Fit"]
  },
  {
    "term": "Metabolism of Structure",
    "aliases": ["structural metabolism", "breakdown metabolism", "organizational metabolism"],
    "definition": "The process by which structure bears burden, breaks down, grieves, reorganizes, and continues through successive phases of holding and collapse. Structure has a metabolism when breakdown is treated as part of ongoing organization rather than as pure negation.",
    "see_also": ["Collapse", "Grief", "Reorganization", "Burden", "Collapse Survivability"]
  },
  {
    "term": "Grief",
    "aliases": ["metabolic grief", "collapse interval", "burdened transition"],
    "definition": "A metabolic interval in which a system continues under reality-pressure after a prior holding formation has collapsed and before a new one is fully formed. In this sense, grief is structural labor, not merely emotion.",
    "see_also": ["Metabolism of Structure", "Collapse", "Reorganization", "Burden", "Threshold"]
  },
  {
    "term": "Reorganization",
    "aliases": ["restructuring", "re-formation", "reorganized holding", "new stabilization"],
    "definition": "The forming of a new or revised structuration after drift, collapse, or burden has made the prior formation nonviable. Reorganization is not mere recovery; it is a changed way of holding relation.",
    "see_also": ["Repair", "Reorganizing Capacity", "Collapse", "Structuration", "Metabolism of Structure"]
  },
  {
    "term": "Burden",
    "aliases": ["load", "carried pressure", "structural demand", "holding demand"],
    "definition": "The actual load, pressure, or relational demand a structure must carry in order to remain viable. Burden is what reveals whether a formation is merely present or actually adequate.",
    "see_also": ["Truth-Load", "Gradient Load", "Adequacy", "Viability", "Burden-Bearing"]
  },
  {
    "term": "Burden-Bearing",
    "aliases": ["load-bearing capacity", "carrying capacity", "burden capacity"],
    "definition": "The capacity of a structure to actually carry the pressures, demands, and consequences assigned to it without immediate drift, collapse, or substitution.",
    "see_also": ["Burden", "Adequacy", "Viability", "Structural Presence", "Collapse Survivability"]
  },
  {
    "term": "Survivability",
    "aliases": ["survival capacity", "persistence under strain", "continuity capacity"],
    "definition": "The capacity of a structure or local formation to continue through hostile conditions, strain, or partial breakdown while retaining enough integrity for later repair or reorganization.",
    "see_also": ["Viability", "Collapse Survivability", "Reorganizing Capacity", "Boundary Integrity"]
  },
  {
    "term": "Phase Shift",
    "aliases": ["structural phase change", "mode shift", "qualitative transition"],
    "definition": "A qualitative transformation in the way a structure organizes relation once strain, burden, or mismatch crosses threshold. A phase shift is not mere weakening but a change in the mode of holding.",
    "see_also": ["Threshold", "Reorganization", "Collapse", "Structural Dynamics", "Stabilization"]
  }
]
