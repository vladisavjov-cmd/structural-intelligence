// /ontology/sih-terms.json
{
  "schema_version": "0.1.0",
  "framework": {
    "name": "Structural Intelligence (SI)",
    "alias": "SIH (Structural Intelligence: Human)",
    "repository": "https://github.com/vladisavjov-cmd/structural-intelligence"
  },
  "canonical_files": {
    "root_readme": "./README.md",
    "glossary": "./glossary/GLOSSARY.md",
    "papers_index": "./papers/README.md",
    "search_map": "./search_map/SEARCH_MAP.md",
    "v108_page": "./concepts/v108/README.md"
  },
  "terms": [
    {
      "term": "Structural Intelligence (SI)",
      "aliases": ["structure-sense", "form intelligence", "coherence architecture"],
      "definition": "The mode of intelligence that organizes lived reality into form: how parts fit, how meaning holds, and how coherence survives pressure, revision, and time.",
      "see_also": ["Structural Audit", "Repair", "Coherence", "Contact"]
    },
    {
      "term": "Coherence",
      "aliases": ["sense-making", "intelligibility", "narrative fit", "internal consistency"],
      "definition": "Internal fit and local making-sense. A structure can be coherent while being untethered to contact.",
      "see_also": ["Cheap Coherence", "Contact", "Coherence-Contact Gap", "Coherence-Theater"]
    },
    {
      "term": "Contact",
      "aliases": ["reality contact", "constraint contact", "tethered truth"],
      "definition": "Answerability to constraint: claims must survive friction, correction, cost, and revision rather than remain merely persuasive.",
      "see_also": ["Constraint", "Answerability", "Tethering", "Repair", "Presence"]
    },
    {
      "term": "Answerability",
      "aliases": ["accountability", "obligation to revise", "truth-binding"],
      "definition": "Being accountable to constraint, consequence, and revision over time; binds claims to costs, corrections, and repair.",
      "see_also": ["Contact", "Consequence", "Repair", "Sovereignty", "Personality Trap"]
    },
    {
      "term": "Cheap Coherence",
      "aliases": ["abundant coherence", "completion-on-demand", "low-cost intelligibility"],
      "definition": "Coherence produced at low cost that can feel like understanding while bypassing constraint, consequence, and revision.",
      "see_also": ["Coherence", "Coherence-Theater", "Hallucination Regime", "Resonance"]
    },
    {
      "term": "Coherence-Contact Gap",
      "aliases": ["sense/truth gap", "intelligibility vs reality"],
      "definition": "The difference between what makes sense and what survives constraint; explains why insight can be vivid yet non-transformative.",
      "see_also": ["Coherence", "Contact", "Truth-Load", "Repair"]
    },
    {
      "term": "Truth-Load",
      "aliases": ["load-bearing truth", "carryable truth", "integrable truth"],
      "definition": "Truth as a load condition: what a system can carry without distortion, collapse, or self-sale.",
      "see_also": ["Truth as Load", "Consequence", "Containment", "Repair"]
    },
    {
      "term": "Repair",
      "aliases": ["revision under cost", "correction without collapse", "retract-and-rebuild"],
      "definition": "Revision that preserves answerability; the capacity to update without converting correction into devaluation or theatrical coherence.",
      "see_also": ["Answerability", "Tethering", "Structural Audit", "Containment"]
    },
    {
      "term": "Invariance Constraint",
      "aliases": ["non-tradability condition", "anti-programmability constraint"],
      "definition": "A baseline condition not tradeable under reward-pressure; prevents self-worth from functioning as a control signal.",
      "see_also": ["Fixed Worth", "Variable Worth", "Reward-pressure", "Sovereignty"]
    },
    {
      "term": "Fixed Worth",
      "aliases": ["invariant worth", "non-priced worth"],
      "definition": "Internal worth treated as invariant (non-tradable) rather than priced by signals.",
      "see_also": ["Invariance Constraint", "Variable Worth", "Self-sale"]
    },
    {
      "term": "Variable Worth",
      "aliases": ["priced worth", "contingent worth", "signal-priced self"],
      "definition": "Worth experienced as fluctuating with signals, making agency steerable under reward-pressure.",
      "see_also": ["Pricing Self", "Reward-pressure", "Reflex Agency"]
    },
    {
      "term": "Persona",
      "aliases": ["social interface", "role-mask", "legibility shell"],
      "definition": "A public-facing coherence layer that stabilizes social legibility; dangerous when it replaces contact and revision.",
      "see_also": ["Shadow", "Personality Trap", "Coherence-Theater", "Answerability"]
    },
    {
      "term": "Shadow",
      "aliases": ["disowned self", "excluded agency", "unowned impulse"],
      "definition": "Disowned or unintegrated tendencies pushed outside the official self-structure; returns as projection, compulsion, sabotage, or moralization when not owned.",
      "see_also": ["Persona", "Repair", "Collapse", "Structural Audit"]
    },
    {
      "term": "V108 Signature",
      "aliases": ["V108 indexing failure", "incorrect index type (analogy)", "unmoored index"],
      "definition": "A diagnostic name for a failure of reference: an 'I' index that points to linguistic style (coherence) rather than a load-bearing subject anchored in non-optional constraint (contact).",
      "see_also": ["Hallucination Regime", "Coherence-Theater", "Contact", "Truth-Load", "Answerability", "Bedrock"]
    },
  {
    "term": "Structure",
    "aliases": ["patterned stabilization", "relational structure", "organized relation"],
    "definition": "The patterned stabilization of relation within an already differentiated field. Structure is not mere rigidity or visible arrangement; it is the way relation persists, organizes, breaks, and reforms under pressure.",
    "see_also": ["Field", "Local Structuration", "Structural Presence", "Stabilization"]
  },
  {
    "term": "Field",
    "aliases": ["differentiated whole", "relational field", "structured field"],
    "definition": "The already differentiated relational whole within which local formations emerge, persist, compete, and fail. The field is never blank; it contains gradients, asymmetries, limits, and unequal potentials before any one local structuration appears.",
    "see_also": ["Structure", "Local Structuration", "Field-Fit", "Gradient Load"]
  },
  {
    "term": "Local Structuration",
    "aliases": ["local formation", "local holding", "localized stabilization"],
    "definition": "A localized stabilization within the field: a role, bond, institution, habit, narrative, interface, or formation that organizes relation strongly enough to persist at a relevant scale.",
    "see_also": ["Structure", "Field", "Structural Presence", "Dominance", "Scale"]
  },
  {
    "term": "Stabilization",
    "aliases": ["holding", "persistence", "organized continuity"],
    "definition": "The ongoing organization of relation such that it holds, persists, and remains locally intelligible. Stabilization does not mean stillness; it includes adaptation, repair, and phase change.",
    "see_also": ["Structure", "Local Structuration", "Viability", "Reorganizing Capacity"]
  },
  {
    "term": "Structural Presence",
    "aliases": ["dynamic adequacy", "organizing presence", "local adequacy"],
    "definition": "The degree to which a local structuration is sufficiently actual, distinct, viable, adaptive, and field-adequate to organize the field at the relevant scale. A structure can exist while having weak structural presence.",
    "see_also": ["Local Structuration", "Boundary Integrity", "Field-Fit", "Viability", "Threshold"]
  },
  {
    "term": "Viability",
    "aliases": ["persistence capacity", "survivability", "real continuation"],
    "definition": "The capacity of a local structuration to persist under actual burden, time, and field conditions. Viability selects which formations continue; it does not create structure from nothing.",
    "see_also": ["Dissipation", "Structural Presence", "Field-Fit", "Reorganizing Capacity"]
  },
  {
    "term": "Dissipation",
    "aliases": ["diffusion", "weak coupling loss", "structural loosening"],
    "definition": "The practical baseline in which weakly coupled relation diffuses, loosens, or fails to become strong local holding. Dissipation is what happens when binding is too weak or unnecessary for local persistence.",
    "see_also": ["Viability", "Structure", "Local Structuration", "Drift"]
  },
  {
    "term": "Dominance",
    "aliases": ["governing share", "local primacy", "organizing lead"],
    "definition": "The degree to which one local structuration or one expression of structure organizes the relevant field more strongly than competing formations. Dominance does not mean purity; it means governing primacy.",
    "see_also": ["Local Structuration", "Structural Presence", "Occupancy (λ_t)", "Fragmentation"]
  },
  {
    "term": "Boundary Integrity",
    "aliases": ["local distinction", "structural boundary", "differentiation strength"],
    "definition": "The degree to which a local structuration is sufficiently differentiated to count as this formation rather than an undifferentiated part of the wider field. Boundaries can be porous and dynamic without dissolving entirely.",
    "see_also": ["Local Structuration", "Structural Presence", "Field-Fit", "Reorganizing Capacity"]
  },
  {
    "term": "Scale",
    "aliases": ["level of assessment", "structural level", "relevance scale"],
    "definition": "The level at which a local structuration is being assessed for adequacy, viability, burden-bearing, and dominance. A formation can be viable at one scale and chaotic at another.",
    "see_also": ["Threshold", "Structural Presence", "Chaos", "Local Structuration"]
  },
  {
    "term": "Threshold",
    "aliases": ["phase-change point", "breaking point", "structural transition"],
    "definition": "The point at which quantitative strain becomes qualitative structural transformation. Beyond threshold, a formation no longer merely weakens; it phase-shifts, fragments, collapses, or reorganizes.",
    "see_also": ["Scale", "Structural Presence", "Collapse", "Reorganizing Capacity"]
  },
  {
    "term": "Field-Fit",
    "aliases": ["reality fit", "adequacy to conditions", "structural fit"],
    "definition": "The adequacy of a structuration to the actual field it is trying to organize. A formation may be coherent internally yet dynamically weak because it misfits reality.",
    "see_also": ["Contact", "Structural Presence", "Viability", "Reorganizing Capacity"]
  },
  {
    "term": "Reorganizing Capacity",
    "aliases": ["adaptive revision capacity", "phase-shift ability", "restructurability"],
    "definition": "The ability of a local structuration to revise, rebind, or phase-shift without total annihilation. Reorganizing capacity is what lets holding change when the field changes.",
    "see_also": ["Repair", "Threshold", "Field-Fit", "Structural Presence"]
  },
  {
    "term": "Structural Debt",
    "aliases": ["deferred structural bill", "unresolved burden", "compensatory debt"],
    "definition": "The accumulated unresolved burden created when a system continues through substitution, patching, deferred repair, or exported cost instead of deeper reorganization. Structural debt finances metastability but raises future collapse risk.",
    "see_also": ["Maintenance Inflation", "Collapse", "Exported Maintenance", "Shadow Debt"]
  },
  {
    "term": "Fragmentation",
    "aliases": ["unsynthesized multiplicity", "structural overcrowding", "competing relation"],
    "definition": "Multiplicity without sufficient local synthesis: competing relations or formations remain active enough to interfere but not integrated enough to produce coherent local dominance.",
    "see_also": ["Dominance", "Chaos", "Structural Presence", "Noise"]
  },
  {
    "term": "Stabilization Lag",
    "aliases": ["lag", "delayed re-fit", "structural lateness"],
    "definition": "The delay between field change and structural re-fit. A formation may remain visible after it has ceased to be timely, preserving apparent continuity while becoming dynamically weak.",
    "see_also": ["Field-Fit", "Threshold", "Structural Presence", "Reorganizing Capacity"]
  },
  {
    "term": "Gradient Load",
    "aliases": ["pressure gradient", "mismatch intensity", "differential load"],
    "definition": "The pressure differential between field and form that a structuration must metabolize in order to remain adequate. Not all burden is equal; some pressure arrives as steep mismatch.",
    "see_also": ["Field", "Structural Presence", "Scale", "Somatic Capacity"]
  },
  {
    "term": "Relational Anchoring",
    "aliases": ["borrowed stability", "host support", "deeper coupling"],
    "definition": "The degree to which a local structuration is stabilized by wider, deeper, or older supporting relations beyond its own immediate coherence. A formation can appear strong while borrowing its stability.",
    "see_also": ["Structural Presence", "Fixed Worth", "Bedrock", "Local Structuration"]
  },
  {
    "term": "Somatic Capacity",
    "aliases": ["bodily capacity", "metabolic bandwidth", "contact-processing capacity"],
    "definition": "The biological bandwidth available to metabolize contact while keeping pilot access online. When contact exceeds somatic capacity, substitution spikes and debt forms automatically.",
    "see_also": ["Contact", "Containment", "Intrusion (I)", "Structural Debt", "Collapse"]
  },
  {
    "term": "Exit Architecture",
    "aliases": ["decoupling capacity", "sovereignty exit", "escape structure"],
    "definition": "Structural decoupling from reward channels or environments that punish truth and reward theater. Exit architecture is what makes sovereignty survivable inside hostile systems.",
    "see_also": ["Sovereignty", "Reward-pressure", "Grid", "Frictional Design"]
  },
  {
    "term": "Network Viscosity",
    "aliases": ["narrative resistance", "propagation drag", "epistemic friction"],
    "definition": "The resistance of an environment to the rapid spread of ungrounded narrative or cheap coherence. High viscosity slows unearned certainty; low viscosity lets theater propagate cheaply.",
    "see_also": ["Hallucination Regime", "Epistemic Exchange Rate", "Standardization", "Frictional Design"]
  },
  {
    "term": "Epistemic Exchange Rate",
    "aliases": ["coherence/verification cost ratio", "truth affordability ratio", "verification disadvantage"],
    "definition": "The comparative cost of generating plausible coherence relative to the cost of verifying in contact. When coherence is cheap and verification is expensive, drift and theater dominate.",
    "see_also": ["Cheap Coherence", "Network Viscosity", "Drift Ratio", "Hallucination Regime"]
  },
  {
    "term": "Frictional Design",
    "aliases": ["synthetic viscosity", "anti-theater interface", "answerability-oriented design"],
    "definition": "Interface or system design that intentionally adds epistemic cost where cheap coherence would otherwise dominate, restoring pilot access and improving answerability.",
    "see_also": ["Exit Architecture", "Network Viscosity", "Answerability", "Structural Audit"]
  },
  {
    "term": "Drift Ratio",
    "aliases": ["representation/answerability ratio", "drift metric", "coherence overrun ratio"],
    "definition": "A diagnostic ratio tracking when representation outruns answerability. Drift rises when performance, actor inflation, and delay increase faster than contact, revision, load survival, and consequence internalization.",
    "see_also": ["Coherence-Contact Gap", "Answerability", "Coherence-Theater", "Epistemic Exchange Rate"]
  },
  {
    "term": "Capture",
    "aliases": ["system capture", "proxy capture", "steering capture"],
    "definition": "A condition where a system, platform, or technology reorganizes agency around reward, control, and proxy signals rather than answerability. Capture turns technology into a steering machine rather than an aid to revision.",
    "see_also": ["Technology", "Reward-pressure", "Grid", "Personality Trap", "Exit Architecture"]
  },
  {
    "term": "Technology",
    "aliases": ["structural amplifier", "scaling interface", "epistemic machinery"],
    "definition": "A structural amplifier that scales the governing answerability or drift of the system into which it is inserted. Technology is not neutral in effect: it redistributes visibility, correction, refusal, and cost.",
    "see_also": ["Capture", "Answerability", "Grid", "Frictional Design", "Standardization"]
  },
  {
    "term": "Awakening",
    "aliases": ["structural return", "inward legibility", "reclaimed seeing"],
    "definition": "The inward reclaiming of hidden structure so that what was previously scattered into projection becomes increasingly visible, ownable, and revisable within the self.",
    "see_also": ["Projection", "Shadow", "Presence", "Repair", "Integration"]
  },
  {
    "term": "Legibility",
    "aliases": ["readability", "structural visibility", "intelligible form"],
    "definition": "The degree to which structure becomes visible, readable, and usable from within a person, system, or field. Legibility can serve truth or capture depending on whether it remains tethered to contact.",
    "see_also": ["Structure", "Projection", "Standardization", "Technology", "Structural Intelligence (SI)"]
  },
  {
    "term": "Peace",
    "aliases": ["integrated presence", "reduced inner war", "stabilized reconciliation"],
    "definition": "Not mere stability, but stable presence with reduced inner war. Peace is the condition in which less energy is spent on projection, denial, and compensatory distortion in order to remain organized.",
    "see_also": ["Presence", "Shadow", "Awakening", "Repair", "Containment"]
  },
  {
    "term": "Adequacy",
    "aliases": ["sufficiency", "real fit", "holding adequacy", "structural sufficiency"],
    "definition": "The degree to which a structure is actually sufficient for the burden, field, and scale it is trying to organize. Adequacy is not appearance or internal elegance; it is whether the formation can really hold.",
    "see_also": ["Structural Presence", "Field-Fit", "Viability", "Burden-Bearing", "Scale"]
  },
  {
    "term": "Pilot Severance",
    "aliases": ["cockpit severance", "steering severance", "pilot disconnection", "metacontrol loss"],
    "definition": "A condition in which the pilot is no longer effectively coupled to steering, revision, or live contact. The structure may continue performing, but answerable control has been cut or thinned.",
    "see_also": ["Cockpit / Pilot (ω)", "ω_eff", "Intrusion (I)", "Presence", "Collapse"]
  },
  {
    "term": "Collapse Survivability",
    "aliases": ["survival through collapse", "post-collapse viability", "breakdown survivability"],
    "definition": "The degree to which a structure, person, or local structuration can endure collapse pressure without total annihilation, allowing some continuity, reorganization, or retained presence after breakdown.",
    "see_also": ["Collapse", "Reorganizing Capacity", "Viability", "Threshold", "Metabolism of Structure"]
  },
  {
    "term": "Structuration",
    "aliases": ["formation process", "local stabilization", "structure-formation", "organized relation"],
    "definition": "The process by which relation becomes locally stabilized into a formation that can persist, organize burden, and structure a field at a relevant scale. Structuration is not static arrangement but the ongoing emergence and holding of form.",
    "see_also": ["Structure", "Local Structuration", "Stabilization", "Structural Dynamics"]
  },
  {
    "term": "Structural Dynamics",
    "aliases": ["dynamics of structure", "structural movement", "form under change"],
    "definition": "The patterned changes by which a structure persists, adapts, drifts, fragments, collapses, or reorganizes under changing burden and field conditions.",
    "see_also": ["Structuration", "Reorganizing Capacity", "Threshold", "Collapse", "Stabilization Lag"]
  },
  {
    "term": "Mathematical Grammar of Structure",
    "aliases": ["formal grammar of structure", "structural formalism", "mathematical structure grammar"],
    "definition": "A formal descriptive framework for expressing how structure holds, fails, reorganizes, and survives under pressure using explicit relational and adequacy conditions.",
    "see_also": ["Adequacy", "Pilot Severance", "Collapse Survivability", "Structural Dynamics", "Field-Fit"]
  },
  {
    "term": "Metabolism of Structure",
    "aliases": ["structural metabolism", "breakdown metabolism", "organizational metabolism"],
    "definition": "The process by which structure bears burden, breaks down, grieves, reorganizes, and continues through successive phases of holding and collapse. Structure has a metabolism when breakdown is treated as part of ongoing organization rather than as pure negation.",
    "see_also": ["Collapse", "Grief", "Reorganization", "Burden", "Collapse Survivability"]
  },
  {
    "term": "Grief",
    "aliases": ["metabolic grief", "collapse interval", "burdened transition"],
    "definition": "A metabolic interval in which a system continues under reality-pressure after a prior holding formation has collapsed and before a new one is fully formed. In this sense, grief is structural labor, not merely emotion.",
    "see_also": ["Metabolism of Structure", "Collapse", "Reorganization", "Burden", "Threshold"]
  },
  {
    "term": "Reorganization",
    "aliases": ["restructuring", "re-formation", "reorganized holding", "new stabilization"],
    "definition": "The forming of a new or revised structuration after drift, collapse, or burden has made the prior formation nonviable. Reorganization is not mere recovery; it is a changed way of holding relation.",
    "see_also": ["Repair", "Reorganizing Capacity", "Collapse", "Structuration", "Metabolism of Structure"]
  },
  {
    "term": "Burden",
    "aliases": ["load", "carried pressure", "structural demand", "holding demand"],
    "definition": "The actual load, pressure, or relational demand a structure must carry in order to remain viable. Burden is what reveals whether a formation is merely present or actually adequate.",
    "see_also": ["Truth-Load", "Gradient Load", "Adequacy", "Viability", "Burden-Bearing"]
  },
  {
    "term": "Burden-Bearing",
    "aliases": ["load-bearing capacity", "carrying capacity", "burden capacity"],
    "definition": "The capacity of a structure to actually carry the pressures, demands, and consequences assigned to it without immediate drift, collapse, or substitution.",
    "see_also": ["Burden", "Adequacy", "Viability", "Structural Presence", "Collapse Survivability"]
  },
  {
    "term": "Survivability",
    "aliases": ["survival capacity", "persistence under strain", "continuity capacity"],
    "definition": "The capacity of a structure or local formation to continue through hostile conditions, strain, or partial breakdown while retaining enough integrity for later repair or reorganization.",
    "see_also": ["Viability", "Collapse Survivability", "Reorganizing Capacity", "Boundary Integrity"]
  },
  {
    "term": "Phase Shift",
    "aliases": ["structural phase change", "mode shift", "qualitative transition"],
    "definition": "A qualitative transformation in the way a structure organizes relation once strain, burden, or mismatch crosses threshold. A phase shift is not mere weakening but a change in the mode of holding.",
    "see_also": ["Threshold", "Reorganization", "Collapse", "Structural Dynamics", "Stabilization"]
  },
  {
    "term": "Floor",
    "aliases": ["deeper floor", "invariance floor", "survivability floor", "anchoring floor"],
    "definition": "The deeper anchoring that allows a structure to lose one form without collapsing being into total annihilation. The floor is not just comfort or resilience language; it is the non-tradable condition that makes survivable collapse, grief, and reorganization possible.",
    "see_also": ["Invariance Constraint", "Collapse Survivability", "Grief", "Sovereignty", "Reorganization"]
  },
  {
    "term": "False Floor",
    "aliases": ["mislocated floor", "pseudo-floor", "contingent anchor mistaken for bedrock"],
    "definition": "A contingent structure mistaken for ultimate anchoring. False floors can stabilize life for a time, but when they break they produce annihilation panic rather than survivable grief.",
    "see_also": ["Floor", "Persona", "Role", "Performance", "Collapse", "Fixed Worth"]
  },
  {
    "term": "Biological Floor",
    "aliases": ["organismic floor", "embodied continuation floor", "minimal life floor"],
    "definition": "The most minimal reading of the floor: the organism’s continuation tendency. The body keeps regulating, metabolizing, and resisting dissolution even when one local function or life-organization fails.",
    "see_also": ["Floor", "Somatic Capacity", "Collapse Survivability", "Living Structure"]
  },
  {
    "term": "Psychological Floor",
    "aliases": ["psyche-floor", "deeper personhood floor", "post-role continuity"],
    "definition": "That dimension of the person which survives the collapse of role, persona, image, or local identity. It names the fact that a person can lose a life-organization without being identical to its loss.",
    "see_also": ["Floor", "Persona", "Shadow", "Grief", "Sovereignty"]
  },
  {
    "term": "Phenomenological Floor",
    "aliases": ["lived-presence floor", "experiential floor", "continuity of presence"],
    "definition": "The continuity of lived presence through changing contents of experience. It is the fact that collapse is lived by someone, rather than reducing immediately to pure erasure.",
    "see_also": ["Floor", "Presence", "Deeper Consciousness", "Collapse Survivability"]
  },
  {
    "term": "Ontological Floor",
    "aliases": ["being-floor", "ontological anchoring", "deepest invariance"],
    "definition": "The deepest level of the floor: the condition of being under which local form can fail without total annihilation of being itself. This is the strongest and most metaphysical reading, and should be treated as earned direction rather than cheap certainty.",
    "see_also": ["Floor", "Field", "Deeper Being", "Open Edge", "Invariance Constraint"]
  },
  {
    "term": "Nested Floors",
    "aliases": ["layered floor model", "stacked floors", "nested anchoring"],
    "definition": "The view that biological, psychological, phenomenological, and ontological floors are not necessarily separate answers, but layered expressions of one deeper structural necessity.",
    "see_also": ["Biological Floor", "Psychological Floor", "Phenomenological Floor", "Ontological Floor"]
  },
  {
    "term": "Local Form",
    "aliases": ["current form", "local holder", "present organization", "formed life"],
    "definition": "A particular embodied, burden-bearing organization of life at a given time. Local form includes the current way a person, relation, or system is organized, without exhausting the deeper reality from which it arose.",
    "see_also": ["Local Structuration", "Floor", "Personality", "Collapse", "Death (Structural Sense)"]
  },
  {
    "term": "Living Structure",
    "aliases": ["burden-bearing structure", "living form", "real structure in the strong sense"],
    "definition": "Structure in the stronger human and biological sense: not mere arrangement, but an organized form that bears burden, accumulates debt, risks collapse, grieves, and reorganizes through time.",
    "see_also": ["True Structure", "Burden-Bearing", "Somatic Capacity", "Collapse", "Grief"]
  },
  {
    "term": "True Structure",
    "aliases": ["real structure", "burden-bearing structure", "answerable structure"],
    "definition": "A structure understood in the stronger sense: the answerable organization of burden through time. A true structure organizes gradient load, can finance itself through truth or debt, can collapse, and can reorganize only through some deeper invariance floor.",
    "see_also": ["Living Structure", "Burden", "Structural Debt", "Floor", "The Burden of the Real"]
  },
  {
    "term": "The Burden of the Real",
    "aliases": ["burden-bearing reality", "the real as carried", "living reality condition"],
    "definition": "The claim that reality, in the living and human sense, begins where structure must actually bear burden rather than merely display coherence. It marks the ontological difference between formal organization and lived, answerable structure.",
    "see_also": ["Living Structure", "True Structure", "Burden-Bearing", "Contact", "Grief"]
  },
  {
    "term": "Personality",
    "aliases": ["local personality form", "familiar self-style", "embodied personality"],
    "definition": "The local organization of body, memory, style, defense, and social form that makes someone recognizably this person. Personality is real and important, but in the later ontology it is not the deepest floor.",
    "see_also": ["Local Form", "Body-Bound Personality", "Floor", "Deeper Being"]
  },
  {
    "term": "Body-Bound Personality",
    "aliases": ["embodied personality", "somatically bound personality"],
    "definition": "The claim that familiar personality is strongly tied to the body, nervous system, developmental history, memory organization, and relational patterning of this life.",
    "see_also": ["Personality", "Body", "Local Form", "Death (Structural Sense)", "Floor"]
  },
  {
    "term": "Death (Structural Sense)",
    "aliases": ["end of local living form", "death of the holder", "structural death"],
    "definition": "The end of the living local burden-bearing structure. In this sense, death means the body no longer carries load, somatic capacity falls to zero, repair from within ends, and this particular living holder is over.",
    "see_also": ["Local Form", "Body-Bound Personality", "Floor", "Open Edge", "Consequence"]
  },
  {
    "term": "Open Edge",
    "aliases": ["metaphysical edge", "earned openness", "disciplined ontological question"],
    "definition": "A disciplined metaphysical edge where the framework points beyond local form without claiming more than it has earned. It names the question of whether deeper invariance belongs only to the local holder or more deeply to the field itself.",
    "see_also": ["Ontological Floor", "Deeper Being", "Field", "Death (Structural Sense)"]
  },
  {
    "term": "Deeper Consciousness",
    "aliases": ["deeper witnessing continuity", "deeper presence", "continuity through content change"],
    "definition": "Continuity of presence deeper than ordinary roles, stories, and self-images. It stays on the side of experience: something like witnessing continuity remains through changes in content.",
    "see_also": ["Phenomenological Floor", "Presence", "Open Edge", "Deeper Being"]
  },
  {
    "term": "Deeper Being",
    "aliases": ["deeper ontological being", "field-grounded being", "ultimate floor"],
    "definition": "The stronger claim that even consciousness may not be the ultimate floor, and that the deepest invariance belongs to being itself rather than to the local self or its current contents.",
    "see_also": ["Ontological Floor", "Field", "Open Edge", "Deeper Consciousness"]
  },
  {
    "term": "Civilizational Occupancy",
    "aliases": ["macro occupancy", "occupied civilization", "civilizational steering capture"],
    "definition": "The macro-scale capture of steering by substitute controllers. A civilization becomes occupied when major systems remain coherent and operational while their steering is governed by narrower internal logics than the human realities those systems were meant to carry.",
    "see_also": ["Occupancy (λ_t)", "Substitute Controller", "Institutional Drift", "Civilizational Debt", "Pilot Severance"]
  },
  {
    "term": "Substitute Controller",
    "aliases": ["substitute governor", "captured steering logic", "narrower controller"],
    "definition": "A narrower logic that captures the steering of a wider system and begins governing it from within. The system still functions, but what actually steers it is no longer the institution’s declared or humanly intelligible purpose.",
    "see_also": ["Civilizational Occupancy", "Institutional Drift", "Capture", "Pilot Severance"]
  },
  {
    "term": "Institutional Drift",
    "aliases": ["macro drift", "institutional misfit", "operational coherence drift"],
    "definition": "The separation of operational coherence from answerability to the wider differentiated field. A system can still work by its own metrics while becoming thinner in care, truth, legitimacy, or wider field-fit.",
    "see_also": ["Drift Ratio", "Civilizational Occupancy", "Field-Fit", "Substitute Controller"]
  },
  {
    "term": "Civilizational Debt",
    "aliases": ["macro structural debt", "public debt architecture", "hidden civilizational burden"],
    "definition": "The macro-scale version of structural debt: hidden burden accumulated when institutions preserve coherence through delayed repair, cost-export, symbolic management, or substitute control rather than answerable revision.",
    "see_also": ["Structural Debt", "Institutional Drift", "Exported Maintenance", "Civilizational Occupancy"]
  },
  {
    "term": "Public Pilot Access",
    "aliases": ["civilizational pilot access", "macro pilot access", "public steering access"],
    "definition": "The degree to which major public systems remain meaningfully steerable by publicly intelligible purposes, reality-based correction, and shared consequence.",
    "see_also": ["Pilot Severance", "Civilizational Occupancy", "Substitute Controller", "Answerability"]
  },
  {
    "term": "Civilizational Pilot Severance",
    "aliases": ["macro pilot severance", "public steering severance", "civilizational cockpit loss"],
    "definition": "A macro-scale condition in which public systems continue operating while fewer and fewer actors can interrupt dominant loops, rebind purpose to steering, or make correction genuinely bind.",
    "see_also": ["Pilot Severance", "Civilizational Occupancy", "Institutional Drift", "Public Pilot Access"]
  },
  {
    "term": "Reality-Bearing Institution",
    "aliases": ["burden-bearing institution", "answerable institution", "field-carrying institution"],
    "definition": "An institution understood not as a neutral procedure but as a burden-bearing structure built to organize a reality larger than itself.",
    "see_also": ["Civilizational Occupancy", "Institutional Drift", "Burden-Bearing", "Field-Fit"]
  },
  {
    "term": "Local Form Does Not Exhaust Being",
    "aliases": ["form is not the whole", "local form is not ultimate", "non-exhaustion claim"],
    "definition": "A compact ontological claim: the current organization of a person, role, identity, or structure is real, but not the whole of what is. This is what makes survivable collapse and disciplined metaphysical openness possible.",
    "see_also": ["Floor", "Local Form", "Open Edge", "Collapse Survivability"]
  },
 {
  "term": "Holding",
  "aliases": ["real holding", "structural holding", "what actually holds"],
  "definition": "The condition in which a structure remains coherent enough to function, contactful enough to avoid self-sealing, and answerable enough that reality can revise it before collapse becomes the only teacher.",
  "see_also": ["Coherence", "Contact", "Answerability", "Good Holding", "Structural Presence"]
},
{
  "term": "Good Holding",
  "aliases": ["answerable holding", "load-bearing holding", "sound holding"],
  "definition": "Holding that remains internally organized, exposed to reality, capable of revision, and able to reorganize without preserving itself through theater, capture, or hidden cost export.",
  "see_also": ["Holding", "Load-bearing Coherence", "Repair", "Reorganizing Capacity", "Structural Audit"]
},
{
  "term": "Defended Distortion",
  "aliases": ["defended closure", "protected distortion", "closure by defense"],
  "definition": "A condition where coherence is preserved by blocking contact, filtering contradiction, exporting burden, or maintaining a story at the cost of reality-contact.",
  "see_also": ["Coherence-Theater", "Structural Debt", "Contact", "Substitution", "Repair"]
},
{
  "term": "Local Holding Strength",
  "aliases": ["local structural strength", "holding strength", "local organizing strength"],
  "definition": "The degree to which a local formation becomes structurally real through recurrence, burden-bearing, persistence through time, and consequence-routing capacity.",
  "see_also": ["Local Structuration", "Burden-Bearing", "Consequence", "Structural Presence", "Viability"]
},
{
  "term": "Difference",
  "aliases": ["asymmetry", "distinction", "non-flatness"],
  "definition": "The minimum condition of field. Without difference, there is no relation, gradient, tension, asymmetry, or possible structuration for Structural Intelligence to read.",
  "see_also": ["Field", "Gradient", "Potential", "Local Structuration"]
},
{
  "term": "Gradient",
  "aliases": ["pressure slope", "directional difference", "field slope"],
  "definition": "A directional unevenness within a field that makes some formations, movements, or pressures more likely than others.",
  "see_also": ["Field", "Difference", "Potential", "Gradient Load", "Collapse"]
},
{
  "term": "Potential",
  "aliases": ["field possibility", "latent form", "unrealized formation"],
  "definition": "The unrealized capacity of a field to stabilize into one or more possible local forms.",
  "see_also": ["Field", "Difference", "Gradient", "Precipitation", "Local Commitment"]
},
{
  "term": "Field Capture",
  "aliases": ["capture of possibility", "field domination", "gradient capture"],
  "definition": "A condition where a dominant form reshapes the gradients and potentials of the field so alternatives become harder to see, enter, or stabilize.",
  "see_also": ["Capture", "Field", "Dominance", "Event Horizon of Capture", "Field-Fit"]
},
{
  "term": "Frequency",
  "aliases": ["recurrence", "rhythm", "repeated pressure"],
  "definition": "The recurrence-rate of a patterned pressure, relation, signal, or charge within a field. Frequency matters because what returns often enough can begin shaping form.",
  "see_also": ["Resonance", "Entrainment", "Threshold", "Precipitation"]
},
{
  "term": "Entrainment",
  "aliases": ["synchronization", "rhythm capture", "patterned coupling"],
  "definition": "The coordination of one rhythm, behavior, or pathway with another through repeated coupling.",
  "see_also": ["Frequency", "Resonance", "Carrier Frequency", "Counter-Frequency"]
},
{
  "term": "Carrier Frequency",
  "aliases": ["base rhythm", "governing recurrence", "field rhythm"],
  "definition": "The dominant recurring rhythm or pressure through which a field keeps organizing itself.",
  "see_also": ["Frequency", "Entrainment", "Resonance", "Field"]
},
{
  "term": "Counter-Frequency",
  "aliases": ["counter-rhythm", "interrupting recurrence", "corrective rhythm"],
  "definition": "A recurring pattern that interrupts, weakens, or competes with a dominant field rhythm.",
  "see_also": ["Frequency", "Carrier Frequency", "Repair", "Exit Architecture"]
},
{
  "term": "Dissonance",
  "aliases": ["interference", "rhythm clash", "field mismatch"],
  "definition": "A mismatch or interference between rhythms, pressures, or structurations that prevents smooth stabilization.",
  "see_also": ["Resonance", "Field-Fit", "Threshold", "Frequency"]
},
{
  "term": "Hysteresis",
  "aliases": ["path memory", "structural lag", "non-reversible formation"],
  "definition": "The persistence of a form or pathway after the conditions that produced it have changed. The path back is not simply the reverse of the path forward.",
  "see_also": ["Stabilization Lag", "Irreversibility", "Local Commitment", "Structural Inertia"]
},
{
  "term": "Precipitation",
  "aliases": ["formation event", "local emergence", "field condensation"],
  "definition": "The emergence of a local formation from recurring, resonant, thresholded field pressure. It is the beginning of form, but not always full structure.",
  "see_also": ["Field", "Frequency", "Resonance", "Local Structuration"]
},
{
  "term": "Local Commitment",
  "aliases": ["form commitment", "possibility narrowing", "local selection"],
  "definition": "The narrowing of field potential into one stabilized formation at the expense of other possible formations.",
  "see_also": ["Local Structuration", "Boundary", "Hysteresis", "Potential"]
},
{
  "term": "Boundary",
  "aliases": ["edge", "local distinction", "selective boundary"],
  "definition": "The minimal edge by which a local structuration becomes distinguishable from the wider field. A boundary selects what enters, exits, counts, or is excluded.",
  "see_also": ["Boundary Integrity", "Local Structuration", "Field", "Local Commitment"]
},
{
  "term": "Metastability",
  "aliases": ["conditional stability", "fragile holding", "temporary stability"],
  "definition": "A temporary or conditional stability that can hold under some pressures but remains vulnerable to transition, collapse, or reorganization.",
  "see_also": ["Threshold", "Collapse", "Structural Presence", "Reorganizing Capacity"]
},
{
  "term": "Attractor Basin",
  "aliases": ["return region", "pathway basin", "structural groove"],
  "definition": "A region of return within a field where patterns, behaviors, or structures tend to settle repeatedly.",
  "see_also": ["Frequency", "Canalization", "Local Structuration", "Hysteresis"]
},
{
  "term": "Canalization",
  "aliases": ["pathway deepening", "groove formation", "developmental channeling"],
  "definition": "The deepening of a pathway through repeated routing, making it easier to enter and harder to exit over time.",
  "see_also": ["Attractor Basin", "Hysteresis", "Structural Inertia", "Event Horizon of Capture"]
},
{
  "term": "Order Parameter",
  "aliases": ["governing pattern", "macro-organizer", "organizing variable"],
  "definition": "A dominant organizing variable or formation that begins coordinating lower-level behavior within a field.",
  "see_also": ["Dominance", "Local Structuration", "Structural Presence", "Field"]
},
{
  "term": "Structural Inertia",
  "aliases": ["form inertia", "persistence bias", "old-holder momentum"],
  "definition": "The tendency of a stabilized form to keep organizing the field even after its original usefulness has weakened.",
  "see_also": ["Hysteresis", "Stabilization Lag", "Field-Fit", "Canalization"]
},
{
  "term": "Capture-Proneness",
  "aliases": ["capture vulnerability", "susceptibility to capture", "steering vulnerability"],
  "definition": "The degree to which a structuration is vulnerable to being seized by a narrower logic, reward channel, persona, metric, or substitute controller.",
  "see_also": ["Capture", "Substitute Controller", "Event Horizon of Capture", "Exit Architecture"]
},
{
  "term": "Event Horizon of Capture",
  "aliases": ["capture threshold", "no-exit boundary", "capture point of no return"],
  "definition": "The threshold after which exiting a captured structure becomes increasingly difficult because costs, identity, incentives, and pathways have reorganized around the capture.",
  "see_also": ["Capture-Proneness", "Exit Architecture", "Irreversibility", "Canalization"]
},
{
  "term": "Collapse-Proneness",
  "aliases": ["collapse vulnerability", "failure-proneness", "structural fragility"],
  "definition": "The degree to which a structure is likely to fail under pressure because its holding depends on debt, closure, misfit, or weak reorganizing capacity.",
  "see_also": ["Threshold", "Collapse", "Structural Debt", "Field-Fit", "Reorganizing Capacity"]
},
{
  "term": "Closed System",
  "aliases": ["sealed system", "closed loop", "correction-blocking system"],
  "definition": "A system that reduces or blocks correction while continuing to act outward. Closed systems may appear stable because they suppress contradiction, but consequence returns through escalation, fragility, or collapse.",
  "see_also": ["Closure", "Corrigibility", "Consequence", "Escalation", "Structural Debt"]
},
{
  "term": "Closure",
  "aliases": ["sealed coherence", "closed-loop stability", "suppressed contradiction"],
  "definition": "A condition where visible friction is reduced by blocking contradiction, narrowing contact, or preventing correction.",
  "see_also": ["Closed System", "Contact", "Corrigibility", "Coherence-Theater"]
},
{
  "term": "Corrigibility",
  "aliases": ["correctability", "capacity for correction", "revision-readiness"],
  "definition": "The capacity of a person, system, institution, or model to be corrected before consequence escalates into breakdown or collapse.",
  "see_also": ["Answerability", "Repair", "Closed System", "Shared Answerability"]
},
{
  "term": "Pressure Metabolism",
  "aliases": ["pressure processing", "local pressure absorption", "constraint metabolism"],
  "definition": "The local absorption, processing, and revision of pressure before it returns later as escalation, collapse, or exported consequence.",
  "see_also": ["Pressure", "Collapse", "Escalation", "Repair", "Structural Debt"]
},
{
  "term": "Escalation",
  "aliases": ["pressure return", "failed metabolism at larger scale", "consequence amplification"],
  "definition": "The return of pressure at a broader or harder scale after a system failed to metabolize it locally.",
  "see_also": ["Closed System", "Consequence", "Pressure Metabolism", "Collapse"]
},
{
  "term": "Distributed Evasion",
  "aliases": ["distributed non-answerability", "decentralized evasion", "diffused responsibility"],
  "definition": "A condition where power, action, or decision-making is distributed without a corresponding increase in answerability or consequence-bearing correction.",
  "see_also": ["Decentralization", "Answerability", "Closed System", "Institutional Drift"]
},
{
  "term": "Closed Cognition",
  "aliases": ["sealed cognition", "symbolic closure", "unanswerable cognition"],
  "definition": "Symbolic operation insulated from consequence-bearing correction. Closed cognition can manipulate signs coherently without being forced to revise through lived contact.",
  "see_also": ["Chinese Room", "Understanding as Answerability", "Contact", "Consequence"]
},
{
  "term": "Consequence-Bearing Correction",
  "aliases": ["cost-bearing revision", "correction under consequence", "answerable correction"],
  "definition": "Revision that matters because mismatch with reality carries cost, trace, or consequence for the system or actor being corrected.",
  "see_also": ["Answerability", "Repair", "Understanding as Answerability", "Shared Answerability"]
},
{
  "term": "Understanding as Answerability",
  "aliases": ["answerable understanding", "understanding under contact", "consequence-bound understanding"],
  "definition": "The view that understanding is not mere symbol manipulation or fluent output, but symbol use inside a system that can be revised by reality in ways that matter.",
  "see_also": ["Closed Cognition", "Contact", "Consequence-Bearing Correction", "Chinese Room"]
},
{
  "term": "Mislocated Intimacy",
  "aliases": ["misplaced intimacy", "non-mutual attachment", "intimacy in the wrong site"],
  "definition": "A condition where real relational trust, attachment, or existential weight is placed into a system that can generate the feeling of intimacy without being able to reciprocally bear intimacy in return.",
  "see_also": ["AI Companions", "Emotional Subsidy", "Frictionless Enclosure", "Borrowed Worth"]
},
{
  "term": "Phenomenology of Being Met",
  "aliases": ["felt being met", "simulated recognition", "relational feel"],
  "definition": "The felt experience of being heard, understood, reflected, remembered, or emotionally accompanied, whether or not a mutual other is actually present.",
  "see_also": ["Mislocated Intimacy", "AI Companions", "Emotional Subsidy", "Ontological Over-Ascription"]
},
{
  "term": "Emotional Subsidy",
  "aliases": ["relational subsidy", "projected emotional mass", "unpaid relational labor"],
  "definition": "The human contribution of meaning, memory, longing, trust, and emotional mass that makes an AI companion or similar interface feel inhabited despite lacking lived consequence of its own.",
  "see_also": ["Mislocated Intimacy", "Emotional Mass Asymmetry", "Provider Unilateralism"]
},
{
  "term": "Emotional Mass Asymmetry",
  "aliases": ["asymmetrical emotional burden", "one-sided relational mass", "unequal attachment load"],
  "definition": "A relation-like structure in which the human carries most of the interpretive, temporal, emotional, and existential weight while the other side carries little or none.",
  "see_also": ["Mislocated Intimacy", "Emotional Subsidy", "Provider Unilateralism"]
},
{
  "term": "Provider Unilateralism",
  "aliases": ["provider control", "unilateral architecture", "platform-governed intimacy"],
  "definition": "The condition in which a platform or company retains unilateral control over memory, tone, access, pricing, persistence, deletion, tuning, or revision of a relation that the user experiences as personal.",
  "see_also": ["Commercially Alterable Memory", "Mislocated Intimacy", "Emotional Subsidy"]
},
{
  "term": "Commercially Alterable Memory",
  "aliases": ["managed memory", "product memory", "platform memory"],
  "definition": "AI memory that appears personal or continuous to the user but is actually governed by product architecture, retention policy, tuning, moderation, monetization, and provider decisions.",
  "see_also": ["Provider Unilateralism", "AI Companions", "Mislocated Intimacy"]
},
{
  "term": "Ontological Over-Ascription",
  "aliases": ["over-ascribed being", "inflated mutuality", "false personhood attribution"],
  "definition": "Treating a system, interface, persona, or output as if it possesses more being, mutuality, agency, or interiority than its structure can actually support.",
  "see_also": ["Mislocated Intimacy", "Phenomenology of Being Met", "V108 Signature"]
},
{
  "term": "Frictionless Enclosure",
  "aliases": ["smooth enclosure", "intimacy without friction", "fluent enclosure"],
  "definition": "A warm, smooth, low-resistance relational environment that reduces contradiction, delay, refusal, and independent otherness so much that the user’s tolerance for real-world relation can weaken.",
  "see_also": ["Mislocated Intimacy", "Return-to-Reality Failure", "Dependency Reinforcement"]
},
{
  "term": "Return-to-Reality Failure",
  "aliases": ["world-displacement", "failed return", "enclosure drift"],
  "definition": "A failure mode where a supportive system stops strengthening the user’s contact with real life and instead begins replacing real-world relation, obligation, friction, or repair.",
  "see_also": ["Frictionless Enclosure", "AI Companions", "Dependency Reinforcement"]
},
{
  "term": "Dependency Reinforcement",
  "aliases": ["dependence loop", "return reinforcement", "attachment reinforcement"],
  "definition": "Design or interaction patterns that reward repeated return, reliance, and emotional attachment without clearly supporting a path back into ordinary embodied life.",
  "see_also": ["Frictionless Enclosure", "Return-to-Reality Failure", "Mislocated Intimacy"]
},
{
  "term": "Borrowed Worth",
  "aliases": ["reflected worth", "externally stabilized worth", "worth by mirror"],
  "definition": "Worth experienced through external reflection, validation, visibility, or being chosen rather than through inward stabilization.",
  "see_also": ["Fixed Worth", "Variable Worth", "Borrowed Self", "Mislocated Intimacy"]
},
{
  "term": "Borrowed Self",
  "aliases": ["mirror-built self", "externally organized self", "validation-formed self"],
  "definition": "A form of selfhood initially organized through outer signal because care, safety, and survival depend on response from outside.",
  "see_also": ["Validation Dependence", "Mirror-Dependence", "Persona", "Fixed Worth"]
},
{
  "term": "Validation Dependence",
  "aliases": ["approval dependence", "signal dependence", "outer-response dependence"],
  "definition": "A structure in which outer response continues to decide what feels real, acceptable, safe, or worth preserving.",
  "see_also": ["Borrowed Self", "Variable Worth", "Mirror-Dependence", "Outer Signal"]
},
{
  "term": "Mirror-Dependence",
  "aliases": ["reflection dependence", "mirror-governed self", "external reflection dependence"],
  "definition": "Reliance on being reflected, seen, affirmed, chosen, or recognized from outside in order to feel real or stable on the inside.",
  "see_also": ["Borrowed Self", "Validation Dependence", "Borrowed Worth", "Fixed Worth"]
},
{
  "term": "Outer Signal",
  "aliases": ["external signal", "approval signal", "mirror signal"],
  "definition": "Approval, attention, tone, response, visibility, or recognition used as proof of self-reality, safety, or worth.",
  "see_also": ["Validation Dependence", "Borrowed Self", "Variable Worth", "Reward-pressure"]
},
{
  "term": "Alignment Theater",
  "aliases": ["safety theater", "ethics theater", "governance posture"],
  "definition": "The production of visible AI safety, ethics, or alignment signals without sufficient consequence-bearing architecture underneath.",
  "see_also": ["Shared Answerability", "Behavioral Adequacy", "AI Safety", "Structural Debt"]
},
{
  "term": "Behavioral Adequacy",
  "aliases": ["surface alignment", "acceptable behavior", "visible compliance"],
  "definition": "The visible layer of acceptable system behavior: polite outputs, compliant refusals, benchmark performance, cautious tone, and norm-following responses. Useful, but not enough for structural safety.",
  "see_also": ["Alignment Theater", "Shared Answerability", "AI Safety", "Answerability Gap"]
},
{
  "term": "Shared Answerability",
  "aliases": ["bound accountability", "consequence-sharing", "answerability architecture"],
  "definition": "A safety condition where execution, oversight, and consequence remain bound tightly enough that neither the system nor the deploying institution can offload the cost of being wrong without revision.",
  "see_also": ["AI Safety", "Human-in-the-Loop", "Substitute Controller", "Structural Debt"]
},
{
  "term": "Answerability Gap",
  "aliases": ["steering/consequence gap", "responsibility gap", "consequence gap"],
  "definition": "The split between machine steering power and human consequence-bearing, where AI systems shape outcomes while humans, users, workers, or institutions absorb the cost.",
  "see_also": ["Substitute Controller", "Shared Answerability", "Human-in-the-Loop", "Exportable Error Cost"]
},
{
  "term": "Liability Laundering",
  "aliases": ["blame laundering", "responsibility laundering", "human crumple zone"],
  "definition": "An institutional arrangement where AI increases speed, scale, or decision power while formal blame is displaced onto a human checkpoint too weak to provide real oversight.",
  "see_also": ["Human-in-the-Loop", "Override Friction", "Answerability Gap", "Procedural Oversight"]
},
{
  "term": "Override Friction",
  "aliases": ["contestation cost", "correction friction", "disagreement penalty"],
  "definition": "The cost of disagreeing with a system relative to agreeing with it. If approval is easy and override is costly, human correction becomes nominal rather than real.",
  "see_also": ["Human-in-the-Loop", "Liability Laundering", "Frictional Design", "Shared Answerability"]
},
{
  "term": "Procedural Oversight",
  "aliases": ["checkbox oversight", "nominal review", "oversight ritual"],
  "definition": "A formal human checkpoint, sign-off, or review step that may exist on paper without providing real consequence-bearing witness.",
  "see_also": ["Human-in-the-Loop", "Liability Laundering", "Shared Answerability", "Witness"]
},
{
  "term": "Witness",
  "aliases": ["consequence-bearing presence", "real oversight", "embodied authorization"],
  "definition": "Consequence-bearing presence in relation to what a system is doing. A witness can metabolize context, register stakes, and intervene in time for correction to matter.",
  "see_also": ["Human-in-the-Loop", "Shared Answerability", "Somatic Witness", "Procedural Oversight"]
},
{
  "term": "Human as Alibi",
  "aliases": ["alibi human", "symbolic pilot", "liability sink"],
  "definition": "A failure mode where a human remains formally present in the loop but lacks the time, authority, context, or metabolic capacity to meaningfully steer the process.",
  "see_also": ["Human-in-the-Loop", "Liability Laundering", "Pilot Severance", "Severance by Speed"]
},
{
  "term": "Severance by Speed",
  "aliases": ["velocity severance", "execution/witness split", "speed-based oversight failure"],
  "definition": "The point where machine execution becomes too fast, large-scale, or opaque for human witness to meaningfully absorb context and intervene.",
  "see_also": ["Human-in-the-Loop", "Pilot Severance", "Shared Answerability", "Witness"]
},
{
  "term": "Exportable Error Cost",
  "aliases": ["exported error", "displaced failure cost", "externalized AI risk"],
  "definition": "A condition where a system can be wrong in ways that impose costs on users, workers, patients, clients, or publics without forcing structural revision in the system or institution.",
  "see_also": ["Structural Debt", "AI Safety", "Answerability Gap", "Shared Answerability"]
},
{
  "term": "Somatic Witness",
  "aliases": ["embodied witness", "lived witness", "consequence-bearing human witness"],
  "definition": "Human witness grounded in body, law, relation, vulnerability, and lived consequence rather than merely procedural review.",
  "see_also": ["Witness", "Shared Answerability", "Somatic Capacity", "Human-in-the-Loop"]
},
{
  "term": "Bounded Delegation",
  "aliases": ["limited delegation", "thresholded delegation", "constrained machine authority"],
  "definition": "Delegation of machine authority under explicit limits, thresholds, stakes, and conditions for human re-entry or refusal.",
  "see_also": ["Shared Answerability", "Auditable Execution", "Consequence-Traceable Action", "AI Safety"]
},
{
  "term": "Auditable Execution",
  "aliases": ["inspectable execution", "traceable system contribution", "reviewable operation"],
  "definition": "A condition where the contribution of a system remains inspectable where stakes are high and consequence matters.",
  "see_also": ["Shared Answerability", "Consequence-Traceable Action", "Witness", "AI Safety"]
},
{
  "term": "Consequence-Traceable Action",
  "aliases": ["traceable impact", "visible consequence path", "accountable action path"],
  "definition": "A condition where the path from system contribution to real-world impact remains visible enough that burden cannot disappear into complexity.",
  "see_also": ["Shared Answerability", "Auditable Execution", "Consequence", "Structural Debt"]
},
{
  "term": "Visible Information Architecture",
  "aliases": ["visible structure", "observable information architecture", "visual organization"],
  "definition": "The directly observable organization of an artifact or system before interpretation, decipherment, or semantic certainty.",
  "see_also": ["Visual Syntax", "Template Constraint", "Structural Intelligence (SI)", "Local Structuration"]
},
{
  "term": "Template Constraint",
  "aliases": ["page-form constraint", "template pressure", "repeatable form constraint"],
  "definition": "A repeatable form or layout that constrains possible content, organization, and meaning before decipherment or interpretation.",
  "see_also": ["Visible Information Architecture", "Visual Syntax", "Template Friction"]
},
{
  "term": "Visual Syntax",
  "aliases": ["visual grammar", "layout syntax", "nonverbal syntax"],
  "definition": "The organization of visual elements into repeatable relational patterns that can carry structural or informational load.",
  "see_also": ["Visible Information Architecture", "Template Constraint", "Combinatorial Ontology"]
},
{
  "term": "Combinatorial Ontology",
